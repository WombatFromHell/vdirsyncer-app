# ──────────────────────────────────────────────
# Multi-user configuration
# ──────────────────────────────────────────────
# Config filename = username (e.g., someuser.conf → "someuser")
#
# Required per-user env vars (uppercase):
#   USERNAME_UID  — host UID for file ownership
#   USERNAME_GID  — host GID for file ownership
#
# Optional per-user env vars (referenced in .conf files):
#   USERNAME_GOOGLE_CID, USERNAME_GOOGLE_KEY, etc.
# ──────────────────────────────────────────────

VERSION=v1.1.1

VDIRSYNCER_CONFIG=/docker/data/config
VDIRSYNCER_DATA=/docker/data/data
VDIRSYNCER_CALENDARS=/docker/data/calendars

# every 30 minutes (by default)
SYNC_SCHEDULE="*/30 * * * *"

SOMEUSER_GOOGLE_CID="some_client_id"
SOMEUSER_GOOGLE_KEY="some_key"
SOMEUSER_ICLOUD_USER="someuser@someemail.com"
SOMEUSER_ICLOUD_APP_PW="some_app_pw"

SOMEUSER_UID=1000
SOMEUSER_GID=1000
