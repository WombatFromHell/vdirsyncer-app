[general]
status_path = "/app/.vdirsyncer/someuser/status"

[pair gcal_sync]
a = "gcal_remote"
b = "gcal_local"
collections = [["main", "someuser@someemail.com", "main"]]
conflict_resolution = "a wins"
metadata = ["color"]

[storage gcal_remote]
type = "google_calendar"
token_file = "/app/.vdirsyncer/someuser/google_token"
client_id.fetch = ["command", "printenv", "SOMEUSER_GOOGLE_CID"]
client_secret.fetch = ["command", "printenv", "SOMEUSER_GOOGLE_KEY"]
start_date = "datetime.now() - timedelta(days=180)"
end_date = "datetime.now() + timedelta(days=365)"

[storage gcal_local]
type = "filesystem"
path = "/app/calendars/someuser/gcal/"
fileext = ".ics"

[pair icloud_sync]
a = "icloud_remote"
b = "icloud_local"
collections = [["main", "home", "main"]]

[storage icloud_remote]
type = "caldav"
url = "https://caldav.icloud.com/"
username.fetch = ["command", "printenv", "SOMEUSER_ICLOUD_USER"]
password.fetch = ["command", "printenv", "SOMEUSER_ICLOUD_APP_PW"]
start_date = "datetime.now() - timedelta(days=180)"
end_date = "datetime.now() + timedelta(days=365)"

[storage icloud_local]
type = "filesystem"
path = "/app/calendars/someuser/icloud/"
fileext = ".ics"
